{
  "name": "iobroker.vis-jsontemplate",
  "version": "4.4.2",
  "description": "vis-jsontemplate",
  "author": {
    "name": "oweitman",
    "email": "oweitman@gmx.de"
  },
  "homepage": "https://github.com/oweitman/ioBroker.vis-jsontemplate",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oweitman/ioBroker.vis-jsontemplate.git"
  },
  "keywords": [
    "ioBroker",
    "visualization",
    "widgets",
    "JSON template",
    "Smart Home"
  ],
  "dependencies": {},
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@iobroker/build-tools": "^3.0.1",
    "@iobroker/vis-2-widgets-react-dev": "^4.0.4",
    "@iobroker/vis-2-widgets-testing": "^1.0.6",
    "@types/node": "^25.5.2"
  },
  "main": "widgets/vis2jsontemplate/customWidgets.js",
  "files": [
    "admin/",
    "widgets/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "test:package": "mocha test/package --exit",
    "test:widgets": "mocha ./test/*.test.js",
    "test:integration": "mocha test/package --exit",
    "test": "npm run test:package && npm run test:widgets",
    "prepublishOnly": "npm run build-vis1widgets && npm run build-vis2widgets",
    "lint": "npm run lint-adapter && npm run lint-vis1widgets && npm run lint-vis2widgets",
    "lint-adapter": "eslint -c eslint.config.mjs .",
    "lint-vis1widgets": "cd widgets/ && npm run lint && cd ../..",
    "lint-vis2widgets": "cd src-widgets/ && npm run lint && cd ../..",
    "build": "npm run build-vis1widgets && npm run build-vis2widgets",
    "build-vis2widgets": "node tasks --javascript-vite",
    "build-vis1widgets": "cd widgets/vis-jsontemplate && npm run build && cd ../..",
    "release": "release-script --all",
    "update-packages": "ncu --upgrade && cd src-widgets && ncu --upgrade && cd ..",
    "npm": "npm i -f && cd src-widgets && npm i -f && cd ..",
    "debug": "npx dev-server watch --noStart --doNotWatch widgets/vis2vis-jsontemplate/**",
    "repocheckerx": "npx github:oweitman/ioBroker.repochecker https://github.com/oweitman/ioBroker.vis-jsontemplate --local",
    "repocheckerx2": "npx @iobroker/repochecker https://github.com/oweitman/ioBroker.vis-jsontemplate",
    "translate": "translate-adapter",
    "translate-widgets-vis2": "node ./bin/translate.js --source src-widgets/src/i18n/",
    "translate-widgets-vis1": "node ./bin/translate.js --source widgets/vis-jsontemplate/i18n/en.json --format single",
    "debugiob": "npx dev-server watch --noStart"
  },
  "bugs": {
    "url": "https://github.com/oweitman/ioBroker.vis-jsontemplate/issues"
  },
  "readmeFilename": "README.md"
}
